# ─────────────────────────────────────
# همان مقادیر DATABASE_URL و BOT_TOKEN ربات را اینجا هم بگذار
# ─────────────────────────────────────

DATABASE_URL=postgresql://user:password@localhost:5432/botdb

# اختیاری: اگر خواستی بکاپ از دیتابیس جداگانه گرفته شود
# در غیر این صورت، همان DATABASE_URL استفاده می‌شود
BACKUP_DATABASE_URL=postgresql://user:password@localhost:5432/botdb

BOT_TOKEN=your_bot_token_here

# یوزرنیم ربات (بدون @) برای ساخت لینک رفرال کاربران
# مثال: BOT_USERNAME=myshopbot  =>  https://t.me/myshopbot?start=ref_REF123ABC
BOT_USERNAME=your_bot_username

JWT_SECRET=change_this_to_a_long_random_secret_string

# پورت API
PORT=3000

# origin های مجاز برای CORS (با کاما جدا کن)
ALLOWED_ORIGINS=http://localhost:5173

# آدرس پنل ادمین (برای دکمه Telegram هنگام افزودن ادمین جدید)
ADMIN_PANEL_URL=http://your-server-ip:8080

# آدرس internal ربات برای broadcast و تحویل دستی
# ربات باید یک endpoint داخلی در این آدرس داشته باشد
BOT_API_URL=http://localhost:3001/internal
